# ATRPE MVP Configuration
# Copy to .env and fill in your values

# Required
LLM_API_KEY=sk-your-deepseek-key

# LLM Configuration
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# Temporal
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=atrpe-workflow-queue

# GitHub Integration
GITHUB_WEBHOOK_SECRET=your-webhook-secret
ZENN_REPO_URL=https://github.com/your-org/zenn-content

# Internal Signal Fallback
INTERNAL_SIGNAL_TOKEN=your-internal-token

# Object Storage
ARTIFACT_STORE_TYPE=local
LOCAL_ARTIFACT_DIR=data/artifacts

# Cloudflare R2 (only if ARTIFACT_STORE_TYPE=r2)
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Experiment Settings
EXPERIMENT_ENV_TYPE=local
DEFAULT_EXPERIMENT_LANGUAGE=go
VERIFICATION_CHECKS=lint,vet,tests,links
MAX_REMEDIATION_ATTEMPTS=3

# Limits
MAX_ACTIVE_WORKFLOWS=3
MAX_PARALLEL_EXPERIMENTS=2
MAX_MONTHLY_ARTICLES=8

# Discovery
COLD_START_ENABLED=true
TOPIC_SOURCES=github_trending,hackernews,zenn_trending,qiita_trending,rss_feeds
